{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "rm -rf node_modules/.vite-temp && tsc -b && vite build",
    "build:prod": "rm -rf node_modules/.vite-temp && tsc -b && BUILD_MODE=prod vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:canon": "RUN_CANONICAL_INTEGRATION_TESTS=true vitest run tests/canonical-games.test.ts",
    "test:gdelt": "deno test --allow-env --allow-read supabase/functions/_shared/live-data-providers.test.ts",
    "test:ui": "vitest --ui",
    "test:firecrawl": "bash bin/test-firecrawl.sh",
    "test:evidence": "bash bin/test-evidence.sh",
    "test:e2e": "node tests/run-tests.js",
    "test:e2e:preview": "sh -c 'PORT=${PLAYWRIGHT_PHASE6_PORT:-4177}; VITE_SUPABASE_URL=https://example.supabase.co VITE_SUPABASE_ANON_KEY=phase6-anon-key VITE_SUPABASE_PUBLISHABLE_KEY=phase6-anon-key npm run build && VITE_SUPABASE_URL=https://example.supabase.co VITE_SUPABASE_ANON_KEY=phase6-anon-key VITE_SUPABASE_PUBLISHABLE_KEY=phase6-anon-key vite preview --host 127.0.0.1 --port \"$PORT\" --strictPort'",
    "test:browser:phase6": "playwright test --config=playwright.config.ts tests/e2e/phase6-browser-smoke.spec.ts --project=chromium",
    "diag:hosted:access": "bash scripts/hosted-access-preflight.sh",
    "diag:functions:hosted": "node scripts/hosted-function-drift.mjs",
    "diag:auth:hosted": "node scripts/hosted-auth-diagnostics.mjs",
    "proof:stripe:hosted": "node scripts/hosted-stripe-proof.mjs",
    "smoke:gdelt:live": "node scripts/gdelt-live-smoke.mjs",
    "smoke:market:live": "node scripts/market-live-smoke.mjs",
    "smoke:retrieval:hosted": "node scripts/retrieval-provider-smoke.mjs",
    "smoke:analyze:providers:hosted": "node scripts/analyze-engine-provider-probe.mjs",
    "smoke:analyze:evidence:hosted": "node scripts/analyze-engine-evidence-smoke.mjs",
    "eval:public-beta:answers": "node scripts/public-beta-answer-eval.mjs",
    "eval:public-beta:six": "node scripts/public-beta-six-question-regression.mjs",
    "smoke:strategist:hosted": "node scripts/hosted-strategist-smoke.mjs",
    "smoke:classroom:hosted": "node scripts/hosted-classroom-smoke.mjs",
    "smoke:schema:hosted": "node scripts/hosted-schema-preflight.mjs",
    "smoke:warroom:hosted": "node scripts/hosted-warroom-smoke.mjs",
    "smoke:insights:hosted": "node scripts/hosted-insights-smoke.mjs",
    "seed:public:beta:forecasts": "node scripts/seed-public-beta-forecasts.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@stripe/stripe-js": "^8.5.3",
    "@supabase/supabase-js": "^2.56.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^3.0.0",
    "embla-carousel-react": "^8.5.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.364.0",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6",
    "recharts": "^2.12.4",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "10.4.20",
    "axios": "^1.7.9",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "8.4.49",
    "tailwindcss": "v3.4.16",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vite-plugin-source-identifier": "1.1.2",
    "vitest": "^2.1.8"
  }
}
