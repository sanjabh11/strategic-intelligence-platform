{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecc.local/skills/ecc-niche-positioning-audit/schemas/evidence-corpus.schema.json",
  "title": "Evidence Corpus (v8)",
  "description": "Machine-readable contract for the evidence corpus including wrapper metadata and individual items",
  "type": "object",
  "required": [
    "audit_id",
    "evidence_items",
    "total_items",
    "types_present",
    "types_missing",
    "evidence_limited_mode",
    "schema_version"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "description": "Audit instance identifier"
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "evidence_type_summary": {
      "type": [
        "object",
        "null"
      ],
      "description": "Summary of evidence types and their grades"
    },
    "total_items": {
      "type": "integer",
      "minimum": 0
    },
    "types_present": {
      "type": "integer",
      "minimum": 0
    },
    "types_missing": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_limited_mode": {
      "type": "boolean",
      "default": false
    },
    "schema_version": {
      "type": "string",
      "const": "v8",
      "description": "Current evidence-corpus schema version; migrate older snapshots before validation"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence_item": {
      "type": "object",
      "required": [
        "evidence_id",
        "type",
        "source",
        "source_tier",
        "timestamp",
        "freshness",
        "grade",
        "confidence",
        "provenance",
        "is_customer_commercial",
        "authority_tier",
        "checked_at",
        "expiry",
        "url_health",
        "content_summary"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^EV-\\d{3}$",
          "description": "Unique identifier for this evidence item"
        },
        "id": {
          "type": "string",
          "pattern": "^EV-\\d{3}$",
          "description": "Alias for evidence_id (legacy compatibility)"
        },
        "type": {
          "type": "string",
          "enum": [
            "product_promise",
            "customer_outcome",
            "user_quote",
            "behavioral_observation",
            "support_ticket",
            "analytics_data",
            "sales_data",
            "pricing_signal",
            "stakeholder_input",
            "competitor_intel",
            "codebase_evidence"
          ],
          "description": "Evidence type from the 11-type taxonomy"
        },
        "source": {
          "type": "string",
          "description": "Where the evidence came from"
        },
        "source_tier": {
          "type": "string",
          "enum": [
            "primary",
            "secondary",
            "inferred"
          ],
          "description": "Primary = direct observation; Secondary = reported by others; Inferred = deduced"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when evidence was collected or published"
        },
        "date_collected": {
          "type": "string",
          "description": "Alias for timestamp (legacy compatibility, date-only accepted)"
        },
        "freshness": {
          "type": "string",
          "enum": [
            "fresh",
            "recent",
            "stale"
          ],
          "description": "fresh = <6mo; recent = 6-18mo; stale = >18mo"
        },
        "grade": {
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW"
          ],
          "description": "Evidence grade"
        },
        "segment": {
          "type": [
            "string",
            "null"
          ],
          "description": "Which customer segment this evidence relates to"
        },
        "geography": {
          "type": [
            "string",
            "null"
          ],
          "description": "Geographic market this evidence applies to"
        },
        "bias": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "self_report",
              "survivorship",
              "selection",
              "confirmation",
              "recency",
              "availability",
              "sponsorship",
              "none"
            ]
          },
          "description": "Potential biases affecting this evidence item",
          "default": [
            "none"
          ]
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^EV-\\d{3}$"
          },
          "description": "IDs of other evidence items that this evidence contradicts",
          "default": []
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in this evidence item (0=none, 1=certain)"
        },
        "provenance": {
          "type": "string",
          "description": "Full chain of how this evidence was obtained"
        },
        "is_customer_commercial": {
          "type": "boolean",
          "description": "True if evidence is from customer or commercial sources"
        },
        "authority_tier": {
          "type": "string",
          "enum": ["tier-1", "tier-2", "tier-3"],
          "description": "tier-1 = peer-reviewed/official; tier-2 = reputable secondary; tier-3 = anecdotal/inferred",
          "default": "tier-3"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this evidence was last verified/checked"
        },
        "expiry": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 date after which this evidence is considered stale and must be re-validated"
        },
        "url_health": {
          "type": ["string", "null"],
          "enum": ["alive", "dead", "redirected", "paywalled", "not_applicable", null],
          "description": "Health status of the source URL if applicable",
          "default": "not_applicable"
        },
        "content_summary": {
          "type": "string",
          "description": "Brief summary of what the evidence says or shows"
        },
        "claim": {
          "type": "string",
          "description": "Alias for content_summary (legacy compatibility)"
        },
        "contradiction_notes": {
          "type": "string",
          "description": "Explanation of any contradictions",
          "default": ""
        }
      },
      "additionalProperties": false
    }
  },
  "version": "v8"
}
