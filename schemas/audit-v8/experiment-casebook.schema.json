{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sip.local/schemas/audit-v8/experiment-casebook.schema.json",
  "title": "Design-only 5+5 experiment casebook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "generated_at", "audit_id", "status", "description",
    "source_pack", "experiment_refs", "rules", "cases", "summary", "validation",
    "approval_required_before_execution", "regulatory_references"
  ],
  "properties": {
    "schema_version": { "const": "experiment-casebook-v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "audit_id": { "type": "string", "minLength": 1 },
    "status": { "const": "designed_not_executed" },
    "description": { "type": "string", "minLength": 1 },
    "source_pack": { "type": "string", "minLength": 1 },
    "experiment_refs": {
      "type": "array",
      "const": ["EXP-007", "EXP-008"]
    },
    "rules": { "type": "object" },
    "cases": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/case" }
    },
    "summary": { "type": "object" },
    "validation": { "type": "object" },
    "approval_required_before_execution": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "regulatory_references": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string" } }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id", "experiment_id", "hypothesis_id", "lane", "target_organization",
        "target_role", "public_source_url", "job_to_be_tested", "demo_surface",
        "discovery_questions", "required_evidence_fields", "consent_requirement",
        "stop_failure_rule", "status", "contact_status"
      ],
      "properties": {
        "case_id": { "type": "string", "pattern": "^CASE-(EDU|ENT)-00[1-5]$" },
        "experiment_id": { "enum": ["EXP-007", "EXP-008"] },
        "hypothesis_id": { "enum": ["H-EDU-4", "H-ENT-0"] },
        "lane": { "enum": ["education", "enterprise"] },
        "target_organization": { "type": "string", "minLength": 1 },
        "target_role": { "type": "string", "minLength": 1 },
        "public_source_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "job_to_be_tested": { "type": "string", "minLength": 1 },
        "demo_surface": { "type": "string", "minLength": 1 },
        "discovery_questions": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 1 } },
        "required_evidence_fields": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "consent_requirement": { "type": "string", "minLength": 1 },
        "stop_failure_rule": { "type": "string", "minLength": 1 },
        "status": { "const": "designed_not_executed" },
        "contact_status": { "const": "not_contacted" },
        "moblab_complement_note": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "lane": { "const": "education" } }, "required": ["lane"] },
          "then": {
            "properties": {
              "case_id": { "type": "string", "pattern": "^CASE-EDU-00[1-5]$" },
              "experiment_id": { "const": "EXP-007" },
              "hypothesis_id": { "const": "H-EDU-4" }
            },
            "required": ["moblab_complement_note"]
          }
        },
        {
          "if": { "properties": { "lane": { "const": "enterprise" } }, "required": ["lane"] },
          "then": {
            "properties": {
              "case_id": { "type": "string", "pattern": "^CASE-ENT-00[1-5]$" },
              "experiment_id": { "const": "EXP-008" },
              "hypothesis_id": { "const": "H-ENT-0" }
            }
          }
        }
      ]
    }
  }
}
